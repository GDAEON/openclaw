{
  "agents": {
    "defaults": {
      "model": {
        "primary": "openai/gpt-5.1-codex"
      },
      "models": {
        "openai/gpt-5.1-codex": {
          "alias": "GPT"
        }
      },
      "compaction": {
        "mode": "safeguard"
      }
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "plugins": {
    "entries": {
      "console": {
        "enabled": true
      }
    }
  },
  "channels": {
    "console": {
      "defaultAccount": "default",
      "accounts": {
        "default": {
          "enabled": true,
          "webhookPath": "/console"
        }
      }
    }
  },
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "controlUi": {
      "allowedOrigins": [
        "http://localhost:18789",
        "http://127.0.0.1:18789",
        "http://89.169.189.122:18789"
      ],
      "dangerouslyDisableDeviceAuth": true
    }
  }
}
